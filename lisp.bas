10 REM SECTORLISP FOR COMMODORE 64
20 DIM AS$(64)
30 DIM CH%(256),CD%(256)
40 DIM SK%(64),S1%(64),S2%(64),S3%(64)
50 NA%=0:NC%=0:EA%=0:SP%=0
60 TK$="NIL":GOSUB 1000:KN%=AX%:TK$="T":GOSUB 1000:KT%=AX%
70 TK$="QUOTE":GOSUB 1000:KQ%=AX%:TK$="COND":GOSUB 1000:KC%=AX%
80 TK$="ATOM":GOSUB 1000:KA%=AX%:TK$="EQ":GOSUB 1000:KE%=AX%
90 TK$="CAR":GOSUB 1000:KR%=AX%:TK$="CDR":GOSUB 1000:KD%=AX%
95 TK$="CONS":GOSUB 1000:KO%=AX%
100 PRINT "* ";:INPUT IN$
110 IX%=1:GOSUB 2000
120 EE%=RV%:EA%=0:GOSUB 3000
130 PO%=EV%:GOSUB 5000
140 PRINT:GOTO 100
150 END
1000 REM INTERN: TK$ -> AX%
1010 FOR AX%=1 TO NA%
1020 IF AS$(AX%)=TK$ THEN RETURN
1030 NEXT AX%
1040 NA%=NA%+1:AS$(NA%)=TK$:AX%=NA%
1050 RETURN
2000 REM READ_EXPR: IN$,IX% -> RV%
2005 IF IX%>LEN(IN$) THEN RV%=KN%:RETURN
2010 IF MID$(IN$,IX%,1)<=" " THEN IX%=IX%+1:GOTO 2005
2015 IF MID$(IN$,IX%,1)<>"(" THEN GOTO 2030
2020 IX%=IX%+1:GOSUB 2100:RETURN
2030 TK$=""
2035 IF IX%>LEN(IN$) THEN GOTO 2055
2040 C$=MID$(IN$,IX%,1)
2045 IF C$<=" " OR C$="(" OR C$=")" THEN GOTO 2055
2050 TK$=TK$+C$:IX%=IX%+1:GOTO 2035
2055 IF TK$="" THEN RV%=KN%:RETURN
2060 GOSUB 1000:RV%=AX%:RETURN
2100 REM READ_LIST: IN$,IX% -> RV%
2102 RH%=0:RT%=0
2105 IF IX%>LEN(IN$) THEN RV%=RH%:RETURN
2110 IF MID$(IN$,IX%,1)<=" " THEN IX%=IX%+1:GOTO 2105
2115 IF MID$(IN$,IX%,1)=")" THEN IX%=IX%+1:RV%=RH%:RETURN
2120 SP%=SP%+1:S1%(SP%)=RH%:S2%(SP%)=RT%
2125 GOSUB 2000:RP%=RV%
2130 RH%=S1%(SP%):RT%=S2%(SP%):SP%=SP%-1
2135 CC%=RP%:DD%=0:GOSUB 6000
2140 IF RH%=0 THEN RH%=RV%:RT%=RV%:GOTO 2105
2145 CD%(-RT%)=RV%:RT%=RV%
2150 GOTO 2105
3000 REM EVAL: EE%,EA% -> EV%
3002 IF EE%=0 THEN EV%=0:RETURN
3004 IF EE%>0 THEN SX%=EE%:SA%=EA%:GOSUB 4000:RETURN
3006 IF CH%(-EE%)<>KQ% THEN GOTO 3012
3008 EV%=CH%(-CD%(-EE%)):RETURN
3012 IF CH%(-EE%)<>KC% THEN GOTO 3018
3014 EC%=CD%(-EE%):GOSUB 3200:RETURN
3018 EF%=CH%(-EE%):EM%=CD%(-EE%):GOSUB 3100
3020 AF%=EF%:AX%=EV%:AA%=EA%:GOSUB 3300:RETURN
3100 REM EVLIS: EM%,EA% -> EV%
3102 EG%=0:ES%=0
3105 IF EM%=0 THEN EV%=EG%:RETURN
3110 SP%=SP%+1:S1%(SP%)=EM%:S2%(SP%)=EG%:S3%(SP%)=ES%
3115 EE%=CH%(-EM%):GOSUB 3000:EP%=EV%
3120 EM%=S1%(SP%):EG%=S2%(SP%):ES%=S3%(SP%):SP%=SP%-1
3125 CC%=EP%:DD%=0:GOSUB 6000
3130 IF EG%=0 THEN EG%=RV%:ES%=RV%:GOTO 3140
3135 CD%(-ES%)=RV%:ES%=RV%
3140 EM%=CD%(-EM%):GOTO 3105
3200 REM EVCON: EC%,EA% -> EV%
3205 IF EC%>=0 THEN PRINT "?COND":PRINT:SP%=0:GOTO 100
3210 SP%=SP%+1:S1%(SP%)=EC%
3215 EE%=CH%(-CH%(-EC%)):GOSUB 3000:ET%=EV%
3220 EC%=S1%(SP%):SP%=SP%-1
3225 IF ET%<>0 THEN EE%=CH%(-CD%(-CH%(-EC%))):GOSUB 3000:RETURN
3230 EC%=CD%(-EC%):GOTO 3205
3300 REM APPLY: AF%,AX%,AA% -> EV%
3302 IF AF%<0 THEN GOTO 3380
3305 IF AF%<>KO% THEN GOTO 3312
3307 CC%=CH%(-AX%):DD%=CH%(-CD%(-AX%)):GOSUB 6000:EV%=RV%:RETURN
3312 IF AF%<>KE% THEN GOTO 3320
3314 EV%=KN%:IF CH%(-AX%)=CH%(-CD%(-AX%)) THEN EV%=KT%
3316 RETURN
3320 IF AF%<>KA% THEN GOTO 3328
3322 EV%=KN%:IF CH%(-AX%)>=0 THEN EV%=KT%
3324 RETURN
3328 IF AF%=KR% THEN EV%=CH%(-CH%(-AX%)):RETURN
3332 IF AF%=KD% THEN EV%=CD%(-CH%(-AX%)):RETURN
3336 PRINT "?";AS$(AF%):PRINT:SP%=0:GOTO 100
3380 REM LAMBDA: AF%,AX%,AA% -> EV%
3382 PX%=CH%(-CD%(-AF%)):PY%=AX%:PA%=AA%:GOSUB 4100
3384 SP%=SP%+1:SK%(SP%)=EA%:EA%=EV%
3385 EE%=CH%(-CD%(-CD%(-AF%)))
3386 GOSUB 3000
3388 EA%=SK%(SP%):SP%=SP%-1:RETURN
4000 REM ASSOC: SX%,SA% -> EV%
4005 IF SA%=0 THEN PRINT "?";AS$(SX%):PRINT:SP%=0:GOTO 100
4010 IF CH%(-CH%(-SA%))=SX% THEN EV%=CD%(-CH%(-SA%)):RETURN
4020 SA%=CD%(-SA%):GOTO 4005
4100 REM PAIRLIS: PX%,PY%,PA% -> EV%
4102 RG%=0:RS%=0
4105 IF PX%<>0 THEN GOTO 4110
4107 IF RS%<>0 THEN CD%(-RS%)=PA%
4108 EV%=RG%:IF RG%=0 THEN EV%=PA%
4109 RETURN
4110 PN%=CH%(-PX%):PV%=CH%(-PY%)
4115 IF PA%<>0 THEN IF CH%(-CH%(-PA%))=PN% THEN PA%=CD%(-PA%)
4120 CC%=PN%:DD%=PV%:GOSUB 6000:PP%=RV%
4125 CC%=PP%:DD%=0:GOSUB 6000
4130 IF RG%=0 THEN RG%=RV%:RS%=RV%:GOTO 4145
4135 CD%(-RS%)=RV%:RS%=RV%
4145 PX%=CD%(-PX%):PY%=CD%(-PY%):GOTO 4105
5000 REM PRINT_OBJ: PO%
5002 IF PO%=0 THEN PRINT "NIL";:RETURN
5004 IF PO%>0 THEN PRINT AS$(PO%);:RETURN
5006 PRINT "(";
5008 SP%=SP%+1:S1%(SP%)=PO%
5010 PO%=CH%(-S1%(SP%)):GOSUB 5000
5012 PO%=CD%(-S1%(SP%)):SP%=SP%-1
5014 IF PO%=0 THEN PRINT ")";:RETURN
5016 IF PO%<0 THEN PRINT " ";:SP%=SP%+1:S1%(SP%)=PO%:GOTO 5010
5018 PRINT " . ";:GOSUB 5000:PRINT ")";:RETURN
6000 REM CONS_ALLOC: CC%,DD% -> RV%
6005 IF NC%>=256 THEN PRINT "?HEAP FULL":END
6010 NC%=NC%+1:CH%(NC%)=CC%:CD%(NC%)=DD%:RV%=-NC%
6020 RETURN
