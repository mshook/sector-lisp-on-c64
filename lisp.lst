   767                          
   768                              ; 5012: PO = CD[-S1[SP]]
   769  10b6 a604ca                 LDX zSP : DEX
   770  10b9 bdc01d853abd001e...    LDA s1_lo,X : STA zPP : LDA s1_hi,X : STA zPP+1
   771  10c3 a90038e53aaa           LDA #0 : SEC : SBC zPP : TAX
   772  10c9 bd0016854abd0017...    LDA cd_lo,X : STA zPO : LDA cd_hi,X : STA zPO+1
   773                          
   774                              ; pop S1
   775  10d3 c604                   DEC zSP
   776                          
   777                              ; 5014: if PO=0, print ")"
   778  10d5 a54a054bd006           LDA zPO : ORA zPO+1 : BNE +
   779  10db a92920d2ff60           LDA #')' : JSR CHROUT : RTS
   780                          
   781                          +:  ; 5016: if PO<0 (cons), print " " and continue list
   782  10e1 a54b3018               LDA zPO+1 : BMI .more
   783                              ; 5018: PO>0 (atom) — print " . atom )"
   784  10e5 a92020d2ff             LDA #' ' : JSR CHROUT
   785  10ea a92e20d2ff             LDA #'.' : JSR CHROUT
   786  10ef a92020d2ff             LDA #' ' : JSR CHROUT
   787  10f4 205410                 JSR print_obj
   788  10f7 a92920d2ff60           LDA #')' : JSR CHROUT : RTS
   789                          
   790                          .more:
   791  10fd a92020d2ff             LDA #' ' : JSR CHROUT
   792                              ; push PO, loop
   793  1102 a604                   LDX zSP
   794  1104 a54a9dc01da54b9d...    LDA zPO : STA s1_lo,X : LDA zPO+1 : STA s1_hi,X
   795  110e e604                   INC zSP
   796  1110 4c9610                 JMP .list_loop
   797                          
   798                          ; ============================================================
   799                          ; 6000 CONS_ALLOC
   800                          !zone consalloc
   801                          cons_alloc:
   802  1113 a503c9ff900f           LDA zNC : CMP #255 : BCC +
   803  1119 a952854ca909854d       LDA #<str_eheap : STA zTKP : LDA #>str_eheap : STA zTKP+1
   804  1121 a90085044c5a09         LDA #0 : STA zSP : JMP err_str
   805                          +:
   806  1128 e603                   INC zNC
   807  112a a603                   LDX zNC
   808  112c a5409d0014             LDA zCC   : STA ch_lo,X
   809  1131 a5419d0015             LDA zCC+1 : STA ch_hi,X
   810  1136 a5429d0016             LDA zDD   : STA cd_lo,X
   811  113b a5439d0017             LDA zDD+1 : STA cd_hi,X
   812                              ; RV = -NC (16-bit: lo = 256-NC, hi = $FF)
   813  1140 a90038e5038512         LDA #0 : SEC : SBC zNC : STA zRV
   814  1147 a9ff8513               LDA #$ff : STA zRV+1
   815  114b 60                     RTS
