   254                          ; ============================================================
   255                          ; STRCMP — compare null-terminated strings at zTKP and zASP
   256                          ; Returns: Z set if equal
   257                          !zone strcmp
   258                          strcmp:
   259  0986 a000                   LDY #0
   260                          .lp:
   261  0988 b14c                   LDA (zTKP),Y
   262  098a d14ed00a               CMP (zASP),Y : BNE .ne
   263  098e f000                   BEQ .check_end  ; chars equal; check null
   264                          .check_end:
   265  0990 b14c                   LDA (zTKP),Y    ; if it's null, both ended -> equal
   266  0992 f005                   BEQ .eq
   267  0994 c84c8809               INY : JMP .lp
   268                          .ne:
   269  0998 60                     RTS             ; Z clear
   270                          .eq:
   271  0999 60                     RTS             ; Z set (LDA #0 set it)
   272                          
   273                          ; ============================================================
   274                          ; INTERN_ASP — set zASP to entry for atom k (1-based) in as_tab
   275                          ; Input: zAX = k (1..127)
   276                          ; Computes zASP = as_tab + (k-1)*8
   277                          !zone internasp
   278                          intern_asp:
   279  099a a55038e901             LDA zAX : SEC : SBC #1  ; A = k-1 (0-based)
   280  099f 854e                   STA zASP                 ; use zASP as temp lo
   281  09a1 a900854f               LDA #0 : STA zASP+1
   282  09a5 064e264f               ASL zASP : ROL zASP+1   ; *2
   283  09a9 064e264f               ASL zASP : ROL zASP+1   ; *4
   284  09ad 064e264f               ASL zASP : ROL zASP+1   ; *8 — zASP:zASP+1 = (k-1)*8
   285  09b1 a54e186900854e         LDA zASP : CLC : ADC #<as_tab : STA zASP
   286  09b8 a54f6918854f           LDA zASP+1 : ADC #>as_tab     : STA zASP+1
   287  09be 60                     RTS
   288                          
   289                          ; ============================================================
   290                          ; 1000 INTERN
   291                          !zone intern
   292                          intern:
   293  09bf a9018550               LDA #1 : STA zAX
   294                          .lp:
   295                              ; if zAX > zNA, not found -> allocate
   296  09c3 a502c550900e           LDA zNA : CMP zAX : BCC .new   ; NA < AX -> AX > NA -> not found
   297                              ; set zASP = as_tab entry for zAX
   298  09c9 209a09                 JSR intern_asp
   299  09cc 208609                 JSR strcmp
   300  09cf f005                   BEQ .found
   301  09d1 e6504cc309             INC zAX : JMP .lp
   302                          .found:
   303  09d6 60                     RTS
   304                          .new:
   305  09d7 e602                   INC zNA
   306  09d9 a5028550               LDA zNA : STA zAX
   307  09dd 209a09                 JSR intern_asp          ; zASP = slot for new atom
   308                              ; copy up to 7 bytes + null from zTKP to zASP
   309  09e0 a000                   LDY #0
   310                          .cp:
   311  09e2 b14c914e               LDA (zTKP),Y : STA (zASP),Y
   312  09e6 f00c                   BEQ .pad
   313  09e8 c8c00790f5             INY : CPY #7 : BCC .cp
   314  09ed a900a007914e           LDA #0 : LDY #7 : STA (zASP),Y ; force null at byte 7
   315  09f3 60                     RTS
   316                          .pad:
   317  09f4 c8c008b007             INY : CPY #8 : BCS .done
   318  09f9 a900914e4cf409         LDA #0 : STA (zASP),Y : JMP .pad
   319                          .done:
   320  0a00 60                     RTS
