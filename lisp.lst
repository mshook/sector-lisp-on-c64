   818                          ; 7000 DUMP
   819                          !zone dump
   820                          dump:
   821                              ; AS:
   822  114c a94120d2ff             LDA #'A' : JSR CHROUT
   823  1151 a95320d2ff             LDA #'S' : JSR CHROUT
   824  1156 a93a20d2ff             LDA #':' : JSR CHROUT
   825  115b a201                   LDX #1
   826                          .as_lp:
   827  115d a502f02d               LDA zNA : BEQ .as_done      ; NA=0, nothing to print
   828  1161 8ac5029004f002b0...    TXA : CMP zNA : BCC .as_body : BEQ .as_body : BCS .as_done
   829                          .as_body:
   830                              ; print " X="
   831  116a a92020d2ff             LDA #' ' : JSR CHROUT
   832  116f 8a201612               TXA : JSR print_byte_dec
   833  1173 a93d20d2ff             LDA #'=' : JSR CHROUT
   834                              ; print atom string for atom X
   835  1178 8650209a09             STX zAX : JSR intern_asp
   836  117d a000                   LDY #0
   837  117f b14ef007           .asn: LDA (zASP),Y : BEQ .asne
   838  1183 20d2ffc84c7f11         JSR CHROUT : INY : JMP .asn
   839                          .asne:
   840  118a e84c5d11               INX : JMP .as_lp
   841                          .as_done:
   842  118e a90d20d2ff             LDA #CR : JSR CHROUT
   843                          
   844                              ; CH:
   845  1193 a94320d2ff             LDA #'C' : JSR CHROUT
   846  1198 a94820d2ff             LDA #'H' : JSR CHROUT
   847  119d a93a20d2ff             LDA #':' : JSR CHROUT
   848  11a2 a201                   LDX #1
   849                          .ch_lp:
   850  11a4 a503f027               LDA zNC : BEQ .ch_done
   851  11a8 8ac5039004f002b0...    TXA : CMP zNC : BCC .ch_body : BEQ .ch_body : BCS .ch_done
   852                          .ch_body:
   853  11b1 a92020d2ff             LDA #' ' : JSR CHROUT
   854  11b6 8a201612               TXA : JSR print_byte_dec
   855  11ba a93d20d2ff             LDA #'=' : JSR CHROUT
   856  11bf bd0015201612           LDA ch_hi,X : JSR print_byte_dec
   857  11c5 bd0014201612           LDA ch_lo,X : JSR print_byte_dec
   858  11cb e84ca411               INX : JMP .ch_lp
   859                          .ch_done:
   860  11cf a90d20d2ff             LDA #CR : JSR CHROUT
   861                          
   862                              ; CD:
   863  11d4 a94320d2ff             LDA #'C' : JSR CHROUT
   864  11d9 a94420d2ff             LDA #'D' : JSR CHROUT
   865  11de a93a20d2ff             LDA #':' : JSR CHROUT
   866  11e3 a201                   LDX #1
   867                          .cd_lp:
   868  11e5 a503f027               LDA zNC : BEQ .cd_done
   869  11e9 8ac5039004f002b0...    TXA : CMP zNC : BCC .cd_body : BEQ .cd_body : BCS .cd_done
   870                          .cd_body:
   871  11f2 a92020d2ff             LDA #' ' : JSR CHROUT
   872  11f7 8a201612               TXA : JSR print_byte_dec
   873  11fb a93d20d2ff             LDA #'=' : JSR CHROUT
   874  1200 bd0017201612           LDA cd_hi,X : JSR print_byte_dec
   875  1206 bd0016201612           LDA cd_lo,X : JSR print_byte_dec
   876  120c e84ce511               INX : JMP .cd_lp
   877                          .cd_done:
   878  1210 a90d20d2ff             LDA #CR : JSR CHROUT
   879  1215 60                     RTS
