   881                          !zone printbyte
   882                          ; print_byte_dec: print A as signed decimal (for dump)
   883                          ; handles 0, positive (1..127), and negative ($ff=$fe=$80 as -1..-128)
   884                          print_byte_dec:
   885  1216 f011                   BEQ .zero
   886  1218 1015                   BPL .pos
   887                              ; negative: print '-' then negate
   888  121a 48                     PHA
   889  121b a92d20d2ff             LDA #'-' : JSR CHROUT
   890  1220 68                     PLA
   891  1221 49ff186901             EOR #$ff : CLC : ADC #1     ; negate
   892  1226 4c2f12                 JMP .pos
   893                          .zero:
   894  1229 a93020d2ff60           LDA #'0' : JSR CHROUT : RTS
   895                          .pos:
   896                              ; print 1-3 decimal digits for value 1..255
   897                              ; divide by 100, 10, 1
   898  122f a200                   LDX #0      ; hundreds
   899  1231 c9649006           .h: CMP #100 : BCC .tens
   900  1235 e964e84c3112           SBC #100 : INX : JMP .h
   901                          .tens:
   902  123b 48                     PHA
   903  123c e000f007               CPX #0 : BEQ .skip_h
   904  1240 8a18693020d2ff         TXA : CLC : ADC #'0' : JSR CHROUT
   905                          .skip_h:
   906  1247 68                     PLA
   907  1248 a200                   LDX #0
   908  124a c90a9006           .t: CMP #10 : BCC .ones
   909  124e e90ae84c4a12           SBC #10 : INX : JMP .t
   910                          .ones:
   911  1254 48                     PHA
   912  1255 e000f007               CPX #0 : BEQ .skip_t
   913  1259 8a18693020d2ff         TXA : CLC : ADC #'0' : JSR CHROUT
   914                          .skip_t:
   915  1260 68                     PLA
   916  1261 18693020d2ff           CLC : ADC #'0' : JSR CHROUT
   917  1267 60                     RTS
