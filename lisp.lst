   229                          ; ERROR — print string at zTKP, CR, then restart REPL
   230                          ; Caller sets zTKP before JSR err (or JMP err_repl directly)
   231                          !zone errstr
   232                          err_str:
   233  095a a000                   LDY #0
   234                          .lp:
   235  095c b14cf00c               LDA (zTKP),Y : BEQ .done
