    13                          ; ============================================================
    14                          ; DATA MEMORY
    15                          ; Code ends around $1220 — all data arrays must start well above that.
    16                          ch_lo   = $1400     ; car lo bytes  [index 1..255]
    17                          ch_hi   = $1500     ; car hi bytes
    18                          cd_lo   = $1600     ; cdr lo bytes
    19                          cd_hi   = $1700     ; cdr hi bytes
    20                          as_tab  = $1800     ; atom strings: 8 bytes/atom, atom k at as_tab+(k-1)*8
    21                          in_buf  = $1c00     ; input line buffer (null-terminated)
    22                          tok_buf = $1d00     ; 8-byte token scratch
    23                          sk_lo   = $1d40     ; SK stack lo (saved EA)
    24                          sk_hi   = $1d80     ; SK stack hi
    25                          s1_lo   = $1dc0     ; S1 stack lo
    26                          s1_hi   = $1e00     ; S1 stack hi
    27                          s2_lo   = $1e40     ; S2 stack lo
    28                          s2_hi   = $1e80     ; S2 stack hi
    29                          s3_lo   = $1ec0     ; S3 stack lo
    30                          s3_hi   = $1f00     ; S3 stack hi
    31                          
    32                          ; ============================================================
    33                          ; ZERO PAGE — 1-byte counters/indices
    34                          zNA     = $02       ; NA%  atom count
    35                          zNC     = $03       ; NC%  cons count
    36                          zSP     = $04       ; SP%  sim-stack pointer
    37                          zIX     = $05       ; IX%  input buffer index (0-based)
    38                          
    39                          ; 1-byte builtin atom indices
    40                          zKN     = $06       ; NIL
    41                          zKT     = $07       ; T
    42                          zKQ     = $08       ; QUOTE
    43                          zKC     = $09       ; COND
    44                          zKA     = $0a       ; ATOM
    45                          zKE     = $0b       ; EQ
    46                          zKR     = $0c       ; CAR
    47                          zKD     = $0d       ; CDR
    48                          zKO     = $0e       ; CONS
    49                          
    50                          ; 2-byte LISP values (lo at base addr, hi at base+1)
    51                          zEA     = $10       ; EA%  environment
    52                          zRV     = $12       ; RV%  read / general return value
    53                          zEV     = $14       ; EV%  eval return value
    54                          zEE     = $16       ; EE%  eval: expression
    55                          zEF     = $18       ; EF%  eval: function
    56                          zEM     = $1a       ; EM%  evlis: list
    57                          zEG     = $1c       ; EG%  evlis: head
    58                          zES     = $1e       ; ES%  evlis: tail
    59                          zEP     = $20       ; EP%  evlis: element
    60                          zET     = $22       ; ET%  evcon: test result
    61                          zEC     = $24       ; EC%  evcon: cond list
    62                          zAF     = $26       ; AF%  apply: function
    63                          zAXX    = $28       ; AX%  apply: arg list
    64                          zAA     = $2a       ; AA%  apply: environment
    65                          zSX     = $2c       ; SX%  assoc: key
    66                          zSA     = $2e       ; SA%  assoc: list
    67                          zPX     = $30       ; PX%  pairlis: params
    68                          zPY     = $32       ; PY%  pairlis: values
    69                          zPA     = $34       ; PA%  pairlis: parent env
    70                          zPN     = $36       ; PN%  pairlis: param name
    71                          zPV     = $38       ; PV%  pairlis: param value
    72                          zPP     = $3a       ; PP%  pairlis: cell temp
    73                          zRG     = $3c       ; RG%  pairlis: result head
    74                          zRS     = $3e       ; RS%  pairlis: result tail
    75                          zCC     = $40       ; CC%  cons_alloc: car
    76                          zDD     = $42       ; DD%  cons_alloc: cdr
    77                          zRH     = $44       ; RH%  read_list: head
    78                          zRT     = $46       ; RT%  read_list: tail
    79                          zRP     = $48       ; RP%  read_list: element
    80                          zPO     = $4a       ; PO%  print_obj: object
    81                          zTKP    = $4c       ; token pointer (2-byte address into tok_buf or builtin strings)
    82                          zASP    = $4e       ; atom-string pointer (2-byte address into as_tab)
    83                          zAX     = $50       ; AX%  intern result (1-byte atom index, hi always 0)
    84                          zDM     = $51       ; dump-mode flag: 0=off, 1=on
    85                          
    86                          ; ============================================================
    87                          ; MACROS
    88                          
    89                          ; copy 16-bit ZP src -> dst
    90                          !macro mv16 .d, .s {
    91                              LDA .s   : STA .d
    92                              LDA .s+1 : STA .d+1
    93                          }
    94                          
    95                          ; zero a 16-bit ZP location
    96                          !macro clr16 .d {
    97                              LDA #0 : STA .d : STA .d+1
    98                          }
    99                          
   100                          ; given a cons value in ZP .src, load its 1-based index into X
   101                          ; (cons lo byte = 256-k, negate it: k = -lo)
   102                          !macro cidx .src {
   103                              LDA #0 : SEC : SBC .src
   104                              TAX
   105                          }
   106                          
   107                          ; load CH[cons .src] into A(lo)/Y(hi)
   108                          !macro carof .src {
   109                              LDA #0 : SEC : SBC .src : TAX
   110                              LDA ch_lo,X : LDY ch_hi,X
   111                          }
   112                          
   113                          ; load CD[cons .src] into A(lo)/Y(hi)
   114                          !macro cdrof .src {
   115                              LDA #0 : SEC : SBC .src : TAX
   116                              LDA cd_lo,X : LDY cd_hi,X
   117                          }
   118                          
