   404                          ; 3000 EVAL
   405                          !zone eval
   406                          eval_:
   407                              ; 3002: if EE=0, EV=0
   408  0afd a5160517d007           LDA zEE : ORA zEE+1 : BNE +
   409  0b03 a9008514851560         +clr16 zEV : RTS
